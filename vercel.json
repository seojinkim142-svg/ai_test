{
  "crons": [
    {
      "path": "/api/nicepayments/subscription/charge",
      "schedule": "0 0 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*\\.mp4)",
      "headers": [
        { "key": "Content-Type", "value": "video/mp4" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Accept-Ranges", "value": "bytes" }
      ]
    }
  ]
}
