# For local dev proxy (Vite) or direct calls only.
VITE_OPENAI_API_KEY=your-openai-api-key
VITE_DEEPSEEK_API_KEY=your-deepseek-api-key
# Recommended for production: server-side key used by /api/openai proxy.
OPENAI_API_KEY=your-openai-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key
# Optional feedback notification API base. For native builds, use an absolute HTTPS URL.
VITE_FEEDBACK_API_BASE=/api/feedback
VITE_DOCUMENT_API_BASE=/api/document
# Optional override. In APK/native builds, set absolute URL like:
# https://your-app-domain/api/openai
VITE_OPENAI_BASE_URL=/api/openai
VITE_DEEPSEEK_BASE_URL=https://api.deepseek.com
VITE_AUTH_ENABLED=false
# Required for iOS/Android native builds, OAuth, and payment return URLs.
# Use your public HTTPS domain, not localhost.
VITE_PUBLIC_APP_ORIGIN=https://your-app-domain
# Optional explicit web Supabase OAuth redirect URL
VITE_SUPABASE_REDIRECT_URL=https://your-app-domain/
# Optional native OAuth redirect override. Add this exact URL to the
# Supabase Auth redirect allow-list for Android/iOS builds as well.
VITE_NATIVE_APP_SCHEME=com.tjwls.examstudyai
VITE_NATIVE_AUTH_REDIRECT_URL=com.tjwls.examstudyai://auth/callback
# Supabase ??? supabase.env ??? ????? (??: supabase.env.example)
VITE_KAKAOPAY_API_BASE=/api/kakaopay
KAKAOPAY_SECRET_KEY=your-kakaopay-secret-key
KAKAOPAY_CID=TC0ONETIME
KAKAOPAY_SUBSCRIPTION_CID=TCSUBSCRIP
# DEV_SECRET_KEY for Secret key(dev), SECRET_KEY for production Secret key
KAKAOPAY_AUTH_SCHEME=DEV_SECRET_KEY
KAKAOPAY_API_BASE=https://open-api.kakaopay.com
KAKAOPAY_READY_PATH=/online/v1/payment/ready
KAKAOPAY_APPROVE_PATH=/online/v1/payment/approve
KAKAOPAY_SUBSCRIPTION_CHARGE_PATH=/online/v1/payment/subscription
KAKAOPAY_SUBSCRIPTION_INACTIVE_PATH=/online/v1/payment/manage/subscription/inactive
KAKAOPAY_BILLING_CRON_SECRET=replace-with-a-long-random-secret
# iOS checklist: this must match the same public HTTPS app domain.
KAKAOPAY_CLIENT_ORIGIN=https://your-app-domain
KAKAOPAY_ALLOW_ORIGIN=https://your-app-domain
KAKAOPAY_PORT=8787
VITE_NICEPAYMENTS_CLIENT_ID=your-nice-client-id
VITE_NICEPAYMENTS_RETURN_URL=https://your-app-domain/api/nicepayments/return
VITE_NICEPAYMENTS_API_BASE=/api/nicepayments
VITE_NICEPAYMENTS_JS_URL=https://pay.nicepay.co.kr/v1/js/
NICEPAYMENTS_CLIENT_ID=your-nice-client-id
NICEPAYMENTS_SECRET_KEY=your-nice-secret-key 
# One-time card approval API base.
# Local/test can stay on sandbox. On public hosts, the server falls back to production unless you set this explicitly.
# For preview or staging with test credentials, keep the sandbox URL here.
NICEPAYMENTS_API_BASE=https://sandbox-api.nicepay.co.kr
# NicePayments Postart recurring billing uses REST bill-key APIs with client key + secret key.
# Production generally uses https://api.nicepay.co.kr.
NICEPAYMENTS_SUBSCRIPTION_API_BASE=https://api.nicepay.co.kr
# iOS checklist: this must match the same public HTTPS app domain.
NICEPAYMENTS_CLIENT_ORIGIN=https://your-app-domain
NICEPAYMENTS_PORT=8791
NICEPAYMENTS_BILLING_CRON_SECRET=replace-with-a-long-random-secret
# If you use Vercel Cron, set the same value here so Vercel sends Authorization: Bearer <secret>.
CRON_SECRET=replace-with-the-same-random-secret
VITE_ADMOB_BANNER_ID_ANDROID=ca-app-pub-xxxxxxxxxxxxxxxx/yyyyyyyyyy
# Optional comma-separated device IDs for AdMob consent/debug testing.
VITE_ADMOB_TEST_DEVICE_IDS=
# Android native build uses ADMOB_APP_ID from environment or android/gradle.properties.
VITE_ADSENSE_PUBLISHER_ID=ca-pub-xxxxxxxxxxxxxxxx

# Server-side tier sync (never expose service role key to client)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_USER_TIER_TABLE=user_tiers
SUPABASE_BILLING_SUBSCRIPTIONS_TABLE=billing_subscriptions
DOCUMENT_PORT=8793
DOCUMENT_ALLOW_ORIGIN=https://your-app-domain
# Self-hosted Gotenberg endpoint used for DOCX/PPTX -> PDF conversion.
GOTENBERG_BASE_URL=https://your-gotenberg-host
DOCUMENT_CONVERTER_TIMEOUT_MS=120000

# Optional feedback email notification via Resend.
FEEDBACK_EMAIL_PROVIDER=resend
FEEDBACK_NOTIFY_EMAIL=alerts@example.com
FEEDBACK_FROM_EMAIL=noreply@your-domain.com
FEEDBACK_ALLOW_ORIGIN=https://your-app-domain
RESEND_API_KEY=your-resend-api-key
