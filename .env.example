# For local dev proxy (Vite) or direct calls only.
VITE_OPENAI_API_KEY=your-openai-api-key
# Recommended for production: server-side key used by /api/openai proxy.
OPENAI_API_KEY=your-openai-api-key
# Optional override. In APK/native builds, set absolute URL like:
# https://your-app-domain/api/openai
VITE_OPENAI_BASE_URL=/api/openai
VITE_AUTH_ENABLED=false
# Public app URL for OAuth/KakaoPay redirect in tablet or webview environments
VITE_PUBLIC_APP_ORIGIN=https://your-app-domain
# Optional explicit Supabase OAuth redirect URL (overrides origin + "/")
VITE_SUPABASE_REDIRECT_URL=https://your-app-domain/
# Supabase ??? supabase.env ??? ????? (??: supabase.env.example)
VITE_KAKAOPAY_API_BASE=/api/kakaopay
KAKAOPAY_SECRET_KEY=your-kakaopay-secret-key
KAKAOPAY_CID=TC0ONETIME
# DEV_SECRET_KEY for Secret key(dev), SECRET_KEY for production Secret key
KAKAOPAY_AUTH_SCHEME=SECRET_KEY
KAKAOPAY_API_BASE=https://open-api.kakaopay.com
KAKAOPAY_READY_PATH=/online/v1/payment/ready
KAKAOPAY_APPROVE_PATH=/online/v1/payment/approve
# In production, use your real domain instead of localhost.
KAKAOPAY_CLIENT_ORIGIN=http://localhost:5173
KAKAOPAY_ALLOW_ORIGIN=http://localhost:5173
KAKAOPAY_PORT=8787
VITE_NICEPAYMENTS_CLIENT_ID=your-nice-client-id
VITE_NICEPAYMENTS_RETURN_URL=https://your-app-domain/api/nicepayments/return
VITE_NICEPAYMENTS_API_BASE=/api/nicepayments
VITE_NICEPAYMENTS_JS_URL=https://pay.nicepay.co.kr/v1/js/
NICEPAYMENTS_CLIENT_ID=your-nice-client-id
NICEPAYMENTS_SECRET_KEY=your-nice-secret-key 
NICEPAYMENTS_API_BASE=https://sandbox-api.nicepay.co.kr
NICEPAYMENTS_CLIENT_ORIGIN=http://localhost:5173
NICEPAYMENTS_PORT=8791

# Server-side tier sync (never expose service role key to client)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_USER_TIER_TABLE=user_tiers
